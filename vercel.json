{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "aicodinghub.dev" }],
      "destination": "https://www.aicodinghub.dev/:path*",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ai-coding-hub-eqfd.vercel.app" }],
      "destination": "https://www.aicodinghub.dev/:path*",
      "statusCode": 301
    },
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/docs", "destination": "/docs/claude/claude-code-overview", "permanent": true },
    { "source": "/docs/claude", "destination": "/docs/claude/claude-code-overview", "permanent": true },
    { "source": "/docs/gemini", "destination": "/docs/gemini/quickstart-installation", "permanent": true },
    { "source": "/docs/opencode", "destination": "/docs/opencode/opencode-intro", "permanent": true },
    { "source": "/docs/codex", "destination": "/docs/codex/authentication", "permanent": true },
    { "source": "/docs/playbook", "destination": "/docs/playbook/claude-code-token-context-surgery", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ]
}
